{
  "name": "@shared-utils/server",
  "version": "1.0.0",
  "description": "Shared utilities for server-side operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./turnstile-worker": {
      "types": "./dist/turnstile-worker.d.ts",
      "import": "./dist/turnstile-worker.js",
      "default": "./dist/turnstile-worker.js"
    }
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README-SERVER.md"
  ],
  "private": true,
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && (yarn --version > /dev/null 2>&1 && yarn tsc --outDir ../dist/server || npx tsc --outDir ../dist/server)",
    "build:clean": "rm -f tsconfig.tsbuildinfo && rm -rf ../dist/server && yarn build",
    "dev": "yarn tsc --outDir ../dist/server --watch",
    "cf:deploy": "./deploy-turnstile-worker.sh",
    "cf:deploy:dev": "./deploy-turnstile-worker.sh dev",
    "cf:deploy:staging": "./deploy-turnstile-worker.sh staging",
    "cf:deploy:production": "./deploy-turnstile-worker.sh production",
    "cf:dev": "wrangler dev",
    "test": "yarn build && NODE_OPTIONS=\"--experimental-vm-modules\" yarn jest",
    "test:watch": "yarn build && NODE_OPTIONS=\"--experimental-vm-modules\" yarn jest --watch",
    "test:coverage": "yarn build && NODE_OPTIONS=\"--experimental-vm-modules\" yarn jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-sesv2": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@shared-utils/utils": "workspace:*",
    "express": "^5.2.1",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@cloudflare/workers-types": "^4.20260617.1",
    "@jest/globals": "^30.4.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "babel-jest": "^30.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.101.0"
  }
}
